---
import ModalCustom from "./react/ModalCustom";
import HeroSlider from "./react/HeroSlider";

interface Project {
  featured?: boolean;
  principal?: boolean;
  type?: string;
  image?: string;
  imageM?: string;
  title?: string;
  description?: string;
  front?: string;
  front2?: string;
  back?: string;
}

const { items = [] } = Astro.props;

// Categorizar proyectos
const featuredProjects = items.filter((item: Project) => item.principal || item.featured);
const webApps = items.filter((item: Project) => item.type === 'web app');
const apis = items.filter((item: Project) => item.type === 'api');
const landingPages = items.filter((item: Project) => item.type === 'landing page');

// Función para obtener el color del badge según la tecnología
const getTechColor = (tech: string): string => {
  const colors: Record<string, string> = {
    'Laravel': 'bg-red-500',
    'Vue.js': 'bg-green-500',
    'php': 'bg-blue-500',
    'default': 'bg-gray-500'
  };
  return colors[tech] || colors.default;
};
---

<!-- Banner Principal Premium con Slider -->
<HeroSlider client:load projects={featuredProjects} />




